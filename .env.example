# ==============================================================
#  Tripcash — Arquivo de configuração de ambiente
#  Copie este arquivo para .env e ajuste os valores antes de
#  iniciar o servidor. NÃO commite o .env com dados reais.
# ==============================================================


# ------------------------------------------------------------
# Segurança Flask
# OBRIGATÓRIO em produção. Gere uma chave segura com:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Se não for definida, uma chave aleatória será gerada a cada
# restart (invalidando todas as sessões ativas).
# ------------------------------------------------------------
SECRET_KEY=substitua_por_uma_chave_longa_e_aleatoria


# ------------------------------------------------------------
# Banco de dados PostgreSQL
# Deve corresponder aos valores configurados no serviço 'db'
# do docker-compose.yml
# ------------------------------------------------------------
DB_HOST=db
DB_NAME=tripcashdb
DB_USER=tripuser
DB_PASSWORD=substitua_por_uma_senha_segura


# ------------------------------------------------------------
# Flask (opcional — usado via docker-compose ou CLI local)
# ------------------------------------------------------------
FLASK_APP=tripcash
# FLASK_ENV=development   # Descomente apenas em desenvolvimento
# FLASK_DEBUG=1           # NUNCA ative em produção


# ------------------------------------------------------------
# Controle de Registro de Novos Usuários
# true  = qualquer pessoa pode criar uma conta (padrão)
# false = registro desabilitado; apenas contas já existentes
#         conseguem fazer login. Ideal para uso privado/familiar.
# ------------------------------------------------------------
ALLOW_REGISTRATION=true


# ------------------------------------------------------------
# Workers do Gunicorn
# Para uso leve (3-4 usuários): 1 worker é suficiente.
# Regra geral para carga maior: (2 x número de CPUs) + 1
# ------------------------------------------------------------
GUNICORN_WORKERS=1
