#: tripcash/templates/index.html:13
msgid ""
"Please select an active trip from your list of created trips to start "
"managing expenses."
msgstr ""
"Selecione uma viagem ativa na sua lista de viagens para começar a "
"gerenciar as despesas."

#: tripcash/templates/index.html:14
