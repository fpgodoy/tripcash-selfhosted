msgid "Welcome to category management. You can create new categories, view current ones, or edit and delete them as needed."
msgstr "Bem-vindo ao gerenciamento de categorias. Você pode criar novas categorias, visualizar as existentes ou editá-las e excluí-las conforme necessário."

msgid "Note:"
msgstr "Nota:"

msgid "If you delete a category, all associated expenses will be automatically reassigned to \"Others\"."
msgstr "Se você excluir uma categoria, todas as despesas associadas serão automaticamente reatribuídas para \"Outros\"."

msgid "New Category"
msgstr "Nova Categoria"

msgid "Create Category"
msgstr "Criar Categoria"

msgid "Existing Categories"
msgstr "Categorias Existentes"

msgid "Actions"
msgstr "Ações"

msgid "Delete"
msgstr "Excluir"

msgid "Deleting this category will move all associated expenses to others. Are you sure?"
msgstr "Excluir esta categoria moverá todas as despesas associadas para \"Outros\". Tem certeza?"

msgid "Manage your trips here. Create new ones, or view, edit, and delete existing trips from the list below."
msgstr "Gerencie suas viagens aqui. Crie novas viagens ou visualize, edite e exclua as existentes na lista abaixo."

msgid "Warning:"
msgstr "Atenção:"

msgid "Deleting a trip will also remove all expenses registered under it."
msgstr "Excluir uma viagem também removerá todas as despesas registradas nela."

msgid "Trip Name"
msgstr "Nome da Viagem"

msgid "Existing Trips"
msgstr "Viagens Existentes"

msgid "This will permanently delete the trip and all its expenses. Are you sure?"
msgstr "Isso excluirá permanentemente a viagem e todas as suas despesas. Tem certeza?"

msgid "New Expense"
msgstr "Nova Despesa"

msgid "Are you sure?"
msgstr "Tem certeza?"

msgid "Select a date to filter the total expenses:"
msgstr "Selecione uma data para filtrar o total de despesas:"

msgid "All dates"
msgstr "Todas as datas"

msgid "Filter"
msgstr "Filtrar"

msgid "Edit Category"
msgstr "Editar Categoria"

msgid "New Category Name"
msgstr "Novo Nome da Categoria"

msgid "Edit Trip"
msgstr "Editar Viagem"

msgid "Incorrect username."
msgstr "Nome de usuário incorreto."

msgid "Incorrect password."
msgstr "Senha incorreta."

msgid "Username is required."
msgstr "O nome de usuário é obrigatório."

msgid "Password is required."
msgstr "A senha é obrigatória."

msgid "Passwords do not match. Please try again."
msgstr "As senhas não coincidem. Por favor, tente novamente."

msgid "All fields are required."
msgstr "Todos os campos são obrigatórios."

msgid "Trip name is required."
msgstr "O nome da viagem é obrigatório."

msgid "Incorrect current password."
msgstr "Senha atual incorreta."

msgid "New password and current password are the same."
msgstr "A nova senha é igual à senha atual."

