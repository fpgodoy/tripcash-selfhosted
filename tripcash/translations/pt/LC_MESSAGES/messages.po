# --- Tela de seleção de viagem (No trip selected) ---
msgid "No trip selected"
msgstr "Nenhuma viagem selecionada"

msgid "Please select an active trip from your list of created trips to start managing expenses."
msgstr "Selecione uma viagem ativa na sua lista de viagens para começar a gerenciar as despesas."

msgid "Go to My Trips"
msgstr "Ir para Minhas Viagens"

# --- Botão Select na tela de viagens ---
msgid "Select"
msgstr "Selecionar"

msgid "Paid for"
msgstr "Pagou por"

msgid "Owes part of"
msgstr "Parte em"

msgid "Payment to"
msgstr "Pagamento para"

msgid "Payment from"
msgstr "Recebimento de"

msgid "Personal Expense"
msgstr "Gasto Pessoal"

msgid "Net Balance"
msgstr "Saldo Final"

