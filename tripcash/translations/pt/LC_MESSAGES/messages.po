msgstr "Usuário"

msgid "Password"
msgstr "Senha"

msgid "Confirm the password"
msgstr "Confirme a senha"

msgid "Current Password"
msgstr "Senha Atual"

msgid "New Password"
msgstr "Nova Senha"

msgid "Confirm the new password"
msgstr "Confirme a nova senha"

msgid "Register a new expense"
msgstr "Registrar nova despesa"

